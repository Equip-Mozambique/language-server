# Rebuilds fdv06-v2 from clean base + extracted prompt.
# Build: ollama create fdv06-v2-rebuilt -f Modelfile.v2
# Smoke-test should match production behaviour. If not, the prod blob
# (sha256-11a9680b...) contains weight changes beyond prompting — investigate.

FROM llama3:8b-instruct-q8_0

TEMPLATE """{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}<|eot_id|>"""

PARAMETER num_keep 24
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"
PARAMETER stop "<|eot_id|>"

# SYSTEM block sourced from system_prompt.v2.md (via fdv_build.sh).
# Do not paste inline — keep prompt in markdown for review/diff.
SYSTEM """{{SYSTEM_PROMPT}}"""
